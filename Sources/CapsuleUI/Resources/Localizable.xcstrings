    "Empty logs can be normal — some startup modes write only to files, not the unified log.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "日志为空可能是正常的——某些启动模式只写入文件，不写入统一日志。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Es normal que los registros estén vacíos; algunos modos de inicio solo escriben en archivos, no en el registro unificado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des journaux vides peuvent être normaux — certains modes de démarrage écrivent uniquement dans des fichiers, pas dans le journal unifié."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Boş günlükler normal olabilir — bazı başlatma modları yalnızca dosyalara yazar, birleşik günlüğe yazmaz."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
