    "Your home directory will be mounted %@. Files inside the machine persist across stops; deleting the machine erases them.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的主目录将挂载到 %@。虚拟机内的文件在停止后仍会保留；删除虚拟机将清除这些文件。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu carpeta de inicio se montará %@. Los archivos dentro de la máquina persisten entre paradas; eliminar la máquina los borra."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre dossier de départ sera monté %@. Les fichiers à l'intérieur de la machine persistent d'un arrêt à l'autre ; supprimer la machine les efface."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ana dizininiz %@ konumuna bağlanacak. Makine içindeki dosyalar, makine durdurulsa da kalıcıdır; makineyi silmek bunları yok eder."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホームディレクトリは%@にマウントされます。マシン内のファイルは停止後も保持されますが、マシンを削除すると失われます。"
          }
        }
      }
    },
