    "Copied to %@:%@.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Copied to %1$@:%2$@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已复制到 %1$@:%2$@。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copiado a %1$@:%2$@."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Copié vers %1$@:%2$@."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$@:%2$@ konumuna kopyalandı."
          }
