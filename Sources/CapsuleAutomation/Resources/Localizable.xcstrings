    "Copies a host file into a running container.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "将主机文件复制到正在运行的容器中。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Copia un archivo del host a un contenedor en ejecución."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Copie un fichier de l'hôte dans un conteneur en cours d'exécution."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir ana bilgisayar dosyasını çalışan bir konteynere kopyalar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ホストのファイルを実行中のコンテナにコピーします。"
          }
        }
      }
