{
  "sourceLanguage": "en",
  "strings": {
    "Absolute path inside the container.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "容器内的绝对路径。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruta absoluta dentro del contenedor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chemin absolu à l'intérieur du conteneur."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Konteyner içindeki mutlak yol."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "コンテナ内の絶対パス。"
          }
        }
      }
    },
    "An optional name for the new container.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "新容器的可选名称。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un nombre opcional para el nuevo contenedor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un nom facultatif pour le nouveau conteneur."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni konteyner için isteğe bağlı bir ad."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいコンテナの任意の名前。"
          }
        }
      }
    },
    "Build ${tag} from ${contextPath}": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 ${contextPath} 构建 ${tag}"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compilar ${tag} desde ${contextPath}"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Générer ${tag} depuis ${contextPath}"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "${contextPath} konumundan ${tag} derle"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "${contextPath} から ${tag} をビルド"
          }
        }
      }
    },
    "Build Image": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "构建镜像"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compilar imagen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Générer une image"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İmaj Derle"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "イメージをビルド"
          }
        }
      }
    },
    "Builds an image from a build-context folder.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从构建上下文文件夹构建镜像。"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Compila una imagen a partir de una carpeta de contexto de compilación."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Génère une image à partir d'un dossier de contexte de build."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir derleme bağlamı klasöründen imaj derler."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ビルドコンテキストフォルダからイメージをビルドします。"
          }
        }
      }
    },
    "Built %@.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
